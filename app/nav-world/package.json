{
  "name": "gluepudding-nav-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "assets:world:prepare": "node scripts/prepare-world-assets.mjs",
    "assets:fortune:prepare": "node scripts/prepare-fortune-assets.mjs",
    "assets:fortune:check": "node scripts/prepare-fortune-assets.mjs --check",
    "build": "tsc --noEmit && vite build && npm run assets:prune",
    "assets:check": "node scripts/prune-untracked-frontend-assets.mjs --check",
    "assets:prune": "node scripts/prune-untracked-frontend-assets.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
